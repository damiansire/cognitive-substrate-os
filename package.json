{
  "name": "cognitive-substrate-os",
  "version": "1.0.0",
  "description": "Lightweight, local, filesystem-first AI agent OS (AIOS) in TypeScript, powered by Google Gemini.",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "tsx apps/cli/src/index.ts",
    "daemon": "tsx apps/cli/src/index.ts --daemon",
    "coordinator": "tsx apps/coordinator/src/index.ts",
    "build": "tsc --build",
    "build:bundle": "npm run build -w apps/cli",
    "clean": "tsc --build --clean",
    "rebuild": "tsc --build --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx packages/evals/src/cli.ts",
    "typecheck": "tsc --build --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "private": true
}